NODE_ENV=development
PORT=5000

MONGODB_URI=mongodb://127.0.0.1:27017/lms

JWT_SECRET=replace_key
JWT_EXPIRES_IN=30d

BCRYPT_SALT_ROUNDS=10

CLIENT_URL=http://localhost:5173

# Admin registration security token (required to register first admin)
# Generate a strong random string for this (e.g., using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ADMIN_REGISTRATION_TOKEN=your_secure_admin_token_here

UPLOAD_PATH=uploads/
